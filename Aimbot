local function findPlayer(name)
    if name == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name:lower(), 1, true) then return p end
    end
    return nil
end

local function playerInfo(t)
    local c = t.Character
    local h = c and c:FindFirstChildOfClass("Humanoid")
    return string.format(
        "👤 %s  |  %s\n❤️ HP: %s / %s\n🏆 Team: %s\n📅 Age: %s days\n🆔 ID: %s",
        t.Name, t.DisplayName,
        h and math.floor(h.Health) or "N/A",
        h and math.floor(h.MaxHealth) or "N/A",
        t.Team and t.Team.Name or "None",
        t.AccountAge, t.UserId
    )
end

