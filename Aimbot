local teamBtn = Instance.new("TextButton")
teamBtn.Size = UDim2.new(0.9, 0, 0, 42)
teamBtn.Position = UDim2.new(0.05, 0, 0.52, 0)
teamBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
teamBtn.Text = "Team Check: ON"
teamBtn.TextColor3 = Color3.new(1,1,1)
teamBtn.TextScaled = true
teamBtn.Parent = frame

local aliveBtn = Instance.new("TextButton")
aliveBtn.Size = UDim2.new(0.9, 0, 0, 42)
aliveBtn.Position = UDim2.new(0.05, 0, 0.66, 0)
aliveBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
aliveBtn.Text = "Dead Check: ON"
aliveBtn.TextColor3 = Color3.new(1,1,1)
aliveBtn.TextScaled = true
aliveBtn.Parent = frame

local partLabel = Instance.new("TextLabel")
partLabel.Size = UDim2.new(0.9, 0, 0, 30)
partLabel.Position = UDim2.new(0.05, 0, 0.82, 0)
partLabel.BackgroundTransparency = 1
partLabel.Text = "Aim Part: Head"
partLabel.TextColor3 = Color3.new(1,1,1)
partLabel.TextScaled = true
partLabel.Parent = frame

toggleBtn.MouseButton1Click:Connect(function()
    aimbotEnabled = not aimbotEnabled
    fovCircle.Visible = aimbotEnabled

    if aimbotEnabled then
        if aimbotConn then aimbotConn:Disconnect() end
        aimbotConn = RunService.RenderStepped:Connect(function()
            local target = getClosestPlayer()
            if target then
                local targetPos = target.Position + Vector3.new(0, 1.8, 0)  -- slight head offset
                local current = camera.CFrame
                local targetCFrame = CFrame.lookAt(current.Position, targetPos)
                camera.CFrame = current:Lerp(targetCFrame, 1 / smoothness)
            end
        end)
        toggleBtn.Text = "AIMBOT ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    else
        if aimbotConn then aimbotConn:Disconnect() end
        toggleBtn.Text = "AIMBOT OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    end
end)

wallBtn.MouseButton1Click:Connect(function()
    wallCheck = not wallCheck
    wallBtn.Text = "Wall Check: " .. (wallCheck and "ON" or "OFF")
    wallBtn.BackgroundColor3 = wallCheck and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
end)

teamBtn.MouseButton1Click:Connect(function()
    teamCheck = not teamCheck
    teamBtn.Text = "Team Check: " .. (teamCheck and "ON" or "OFF")
    teamBtn.BackgroundColor3 = teamCheck and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
end)

aliveBtn.MouseButton1Click:Connect(function()
    aliveCheck = not aliveCheck
    aliveBtn.Text = "Dead Check: " .. (aliveCheck and "ON" or "OFF")
    aliveBtn.BackgroundColor3 = aliveCheck and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
end)

-- Click to cycle aim part
partLabel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if aimPart == "Head" then
            aimPart = "HumanoidRootPart"
            partLabel.Text = "Aim Part: Torso"
        elseif aimPart == "HumanoidRootPart" then
            aimPart = "Random"
            partLabel.Text = "Aim Part: Random"
        else
            aimPart = "Head"
            partLabel.Text = "Aim Part: Head"
        end
    end
end)

RunService.RenderStepped:Connect(function()
    fovCircle.Radius = fov
    fovCircle.Position = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
end)

print("✅ Nexis Aimbot loaded with Wall, Team, Dead Check + Smoothness")
StarterGui:SetCore("SendNotification", {
    Title = "Nexis Aimbot",
    Text = "Loaded! Tap AIMBOT OFF to start. Tap labels to change settings.",
    Duration = 6
})
