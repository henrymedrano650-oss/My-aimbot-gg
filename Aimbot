-- ========== STAT ENFORCER ==========
local function startStatLoop()
    if statLoop then statLoop:Disconnect() end
    statLoop = RunService.Heartbeat:Connect(function()
        if not Humanoid or not Humanoid.Parent then return end
        if Humanoid.WalkSpeed ~= currentWalkSpeed then Humanoid.WalkSpeed = currentWalkSpeed end
        if Humanoid.JumpPower ~= currentJumpPower then Humanoid.JumpPower = currentJumpPower end
    end)
end
startStatLoop()

-- ========== NOCLIP ==========
local PARTS = {
    "HumanoidRootPart","UpperTorso","LowerTorso","Head",
    "LeftUpperArm","LeftLowerArm","LeftHand",
    "RightUpperArm","RightLowerArm","RightHand",
    "LeftUpperLeg","LeftLowerLeg","LeftFoot",
    "RightUpperLeg","RightLowerLeg","RightFoot",
    "Torso","Left Arm","Right Arm","Left Leg","Right Leg",
}

local function enableNoclip()
    if noclipConn then noclipConn:Disconnect() end
    origCollision = {}
    for _, p in pairs(Character:GetDescendants()) do
        if p:IsA("BasePart") then origCollision[p] = p.CanCollide; p.CanCollide = false end
    end
    noclipConn = RunService.Stepped:Connect(function()
        if not noclipEnabled or not Character then return end
        for _, n in ipairs(PARTS) do
            local p = Character:FindFirstChild(n)
            if p and p:IsA("BasePart") then p.CanCollide = false end
        end
        for _, p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

local function disableNoclip()
    noclipEnabled = false
    if noclipConn then noclipConn:Disconnect() noclipConn = nil end
    for _, p in pairs(Character:GetDescendants()) do
        if p:IsA("BasePart") then
            p.CanCollide = origCollision[p] ~= nil and origCollision[p] or true
        end
    end
    origCollision = {}
end

-- ========== INVISIBLE ==========
local function enableInvis()
    origTransparency = {}
    if not Character then return end
    for _, p in pairs(Character:GetDescendants()) do
        if p:IsA("BasePart") or p:IsA("Decal") then
            origTransparency[p] = p.Transparency
            p.Transparency = 1
        end
    end
    for _, acc in pairs(Character:GetChildren()) do
        if acc:IsA("Accessory") then
            local h = acc:FindFirstChild("Handle")
            if h then origTransparency[h] = h.Transparency; h.Transparency = 1 end
        end
    end
end

local function disableInvis()
    invisEnabled = false
    if not Character then return end
    for p, t in pairs(origTransparency) do
        if p and p.Parent then p.Transparency = t end
    end
    origTransparency = {}
end

local function refreshInvis()
    if not invisEnabled then return end
    disableInvis()
    invisEnabled = true
    task.wait(0.1)
    enableInvis()
end

-- ========== FPS BOOST ==========
local origLighting = {}

local function applyFPS()
    origLighting = {
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd = Lighting.FogEnd,
        Brightness = Lighting.Brightness,
        Ambient = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
    }
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 100000
    Lighting.Brightness = 1
    Lighting.Ambient = Color3.fromRGB(128,128,128)
    Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
    for _, v in pairs(Lighting:GetChildren()) do
        pcall(function()
            if v:IsA("PostEffect") or v:IsA("Atmosphere") then v.Enabled = false end
        end)
    end
    for _, v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or
               v:IsA("Sparkles") or v:IsA("Beam") or v:IsA("Trail") then v.Enabled = false end
        end)
    end
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

local function removeFPS()
    for k, v in pairs(origLighting) do Lighting[k] = v end
    for _, v in pairs(Lighting:GetChildren()) do
        pcall(function()
            if v:IsA("PostEffect") or v:IsA("Atmosphere") then v.Enabled = true end
        end)
    end
    for _, v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or
               v:IsA("Sparkles") or v:IsA("Beam") or v:IsA("Trail") then v.Enabled = true end
        end)
    end
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
end

